generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RoleName {
  SUPER_ADMIN
  ADMIN
  DEPARTMENT_HEAD
  PROJECT_MANAGER
  EMPLOYEE
  INTERN
  CLIENT_GUEST
}

enum PermissionAction {
  CREATE
  READ
  UPDATE
  DELETE
  APPROVE
  SHARE
  EXPORT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  INVITED
}

enum ProjectType {
  INTERNAL_PRODUCT
  CLIENT_PROJECT
  R_AND_D
  OFFICE_ADMIN
  SALES
  HR
  FINANCE
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  BLOCKED
  REVIEW
  COMPLETED
  PAUSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskStatus {
  BACKLOG
  TO_DO
  IN_PROGRESS
  WAITING
  REVIEW
  DONE
  CANCELLED
}

enum DocumentCategory {
  CONTRACTS
  OFFER_LETTERS
  INVESTOR_AGREEMENTS
  NDAS
  JDS
  COMPANY_POLICIES
  TECHNICAL_DOCS
  CLIENT_PROPOSALS
  MEETING_NOTES
}

enum ApprovalStatus {
  DRAFT
  UNDER_REVIEW
  APPROVED
  SIGNED
  ARCHIVED
}

enum EmployeeStatus {
  CANDIDATE
  OFFERED
  ACTIVE
  PROBATION
  CONTRACTOR
  INTERN
  TERMINATED
  RESIGNED
}

enum CandidateStage {
  APPLIED
  SHORTLISTED
  INTERVIEW_SCHEDULED
  INTERVIEWED
  SELECTED
  OFFER_SENT
  HIRED
  REJECTED
}

enum ProcurementCategory {
  FURNITURE
  AC_COOLING
  ELECTRONICS
  CCTV_SECURITY
  INTERNET
  BRANDING
  LAB_EQUIPMENT
  KITCHEN
  STATIONERY
  MISCELLANEOUS
}

enum ProcurementStatus {
  NEEDED
  QUOTED
  APPROVED
  PURCHASED
  DELIVERED
  INSTALLED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
}

enum ExpenseStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
}

enum ActivityAction {
  LOGIN
  CREATE
  UPDATE
  DELETE
  DEACTIVATE
  ROLE_CHANGE
  STATUS_CHANGE
  UPLOAD
  APPROVAL
  SHARE
  ACCESS_CHANGE
}

model Role {
  id          String           @id @default(cuid())
  name        RoleName         @unique
  label       String
  description String?
  users       User[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Permission {
  id          String             @id @default(cuid())
  resource    String
  action      PermissionAction
  description String?
  roles       RolePermission[]
  createdAt   DateTime           @default(now())

  @@unique([resource, action])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model User {
  id                       String                    @id @default(cuid())
  name                     String
  email                    String                    @unique
  passwordHash             String
  phone                    String?
  avatarUrl                String?
  status                   UserStatus                @default(ACTIVE)
  joiningDate              DateTime?
  salaryVisible            Boolean                   @default(false)
  canViewFinance           Boolean                   @default(false)
  canViewSensitiveDocuments Boolean                  @default(false)
  roleId                   String
  departmentId             String?
  role                     Role                      @relation(fields: [roleId], references: [id])
  department               Department?               @relation("DepartmentMembers", fields: [departmentId], references: [id])
  leadingDepartments       Department[]              @relation("DepartmentHead")
  ownedProjects            Project[]                 @relation("ProjectOwner")
  projectMemberships       ProjectMember[]
  assignedTasks            Task[]                    @relation("TaskAssignee")
  reportedTasks            Task[]                    @relation("TaskReporter")
  comments                 Comment[]
  documentsUploaded        Document[]                @relation("DocumentUploader")
  documentPermissions      DocumentPermission[]
  hrProfile                HRProfile?
  candidatesAssigned       Candidate[]               @relation("CandidateInterviewer")
  expensesPaid             Expense[]                 @relation("ExpensePaidBy")
  expensesApproved         Expense[]                 @relation("ExpenseApprovedBy")
  procurementAssigned      ProcurementItem[]         @relation("ProcurementAssigned")
  meetingsOrganized        Meeting[]                 @relation("MeetingOrganizer")
  meetingParticipants      MeetingParticipant[]
  notifications            Notification[]
  auditLogs                AuditLog[]                @relation("AuditActor")
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt

  @@index([roleId])
  @@index([departmentId])
}

model Department {
  id          String      @id @default(cuid())
  name        String      @unique
  headId      String?
  head        User?       @relation("DepartmentHead", fields: [headId], references: [id])
  members     User[]      @relation("DepartmentMembers")
  projects    Project[]
  tasks       Task[]
  notes       String?
  kpis        Json?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Project {
  id          String          @id @default(cuid())
  name        String
  type        ProjectType
  status      ProjectStatus   @default(PLANNING)
  priority    Priority        @default(MEDIUM)
  startDate   DateTime?
  dueDate     DateTime?
  ownerId     String
  departmentId String?
  clientName  String?
  budget      Decimal?        @db.Decimal(14, 2)
  description String?
  owner       User            @relation("ProjectOwner", fields: [ownerId], references: [id])
  department  Department?     @relation(fields: [departmentId], references: [id])
  members     ProjectMember[]
  tasks       Task[]
  milestones  Milestone[]
  documents   Document[]
  expenses    Expense[]
  meetings    Meeting[]
  comments    Comment[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([ownerId])
  @@index([departmentId])
  @@index([status])
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  access    String   @default("member")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([projectId, userId])
  @@index([userId])
}

model Milestone {
  id          String    @id @default(cuid())
  projectId   String
  title       String
  description String?
  dueDate     DateTime?
  completedAt DateTime?
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Task {
  id                  String        @id @default(cuid())
  title               String
  description         String?
  projectId           String?
  assigneeId          String?
  reporterId          String?
  departmentId        String?
  status              TaskStatus    @default(TO_DO)
  priority            Priority      @default(MEDIUM)
  dueDate             DateTime?
  timeEstimateMinutes Int?
  timeSpentMinutes    Int?
  tags                String[]      @default([])
  approvalRequired    Boolean       @default(false)
  recurringRule       String?
  project             Project?      @relation(fields: [projectId], references: [id])
  assignee            User?         @relation("TaskAssignee", fields: [assigneeId], references: [id])
  reporter            User?         @relation("TaskReporter", fields: [reporterId], references: [id])
  department          Department?   @relation(fields: [departmentId], references: [id])
  subtasks            Subtask[]
  checklist           ChecklistItem[]
  comments            Comment[]
  dependencies        TaskDependency[] @relation("TaskDependency")
  dependents          TaskDependency[] @relation("TaskDependent")
  actionItems         MeetingActionItem[]
  attachments         Document[]    @relation("TaskDocuments")
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([projectId])
  @@index([assigneeId])
  @@index([departmentId])
  @@index([status])
}

model TaskDependency {
  id           String @id @default(cuid())
  taskId       String
  dependsOnId  String
  task         Task   @relation("TaskDependency", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOn    Task   @relation("TaskDependent", fields: [dependsOnId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnId])
}

model Subtask {
  id          String   @id @default(cuid())
  taskId      String
  title       String
  completed   Boolean  @default(false)
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ChecklistItem {
  id          String   @id @default(cuid())
  taskId      String
  label       String
  completed   Boolean  @default(false)
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model Comment {
  id          String    @id @default(cuid())
  body        String
  authorId    String
  projectId   String?
  taskId      String?
  documentId  String?
  meetingId   String?
  mentions    String[]  @default([])
  author      User      @relation(fields: [authorId], references: [id])
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task        Task?     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  document    Document? @relation(fields: [documentId], references: [id], onDelete: Cascade)
  meeting     Meeting?  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Document {
  id            String               @id @default(cuid())
  title         String
  category      DocumentCategory
  status        ApprovalStatus       @default(DRAFT)
  content       String?
  fileUrl       String?
  fileName      String?
  sensitive     Boolean              @default(false)
  uploaderId    String
  projectId     String?
  taskId        String?
  employeeProfileId String?
  uploader      User                 @relation("DocumentUploader", fields: [uploaderId], references: [id])
  project       Project?             @relation(fields: [projectId], references: [id])
  task          Task?                @relation("TaskDocuments", fields: [taskId], references: [id])
  employeeProfile HRProfile?         @relation(fields: [employeeProfileId], references: [id])
  versions      DocumentVersion[]
  comments      Comment[]
  permissions   DocumentPermission[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([category])
  @@index([status])
}

model DocumentVersion {
  id          String   @id @default(cuid())
  documentId  String
  version     Int
  content     String?
  fileUrl     String?
  createdById String?
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([documentId, version])
}

model DocumentPermission {
  id         String   @id @default(cuid())
  documentId String
  userId     String?
  roleId     String?
  canRead    Boolean  @default(true)
  canWrite   Boolean  @default(false)
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([documentId])
  @@index([userId])
}

model HRProfile {
  id                String         @id @default(cuid())
  userId            String         @unique
  employeeCode      String?        @unique
  status            EmployeeStatus @default(ACTIVE)
  joiningDate       DateTime?
  probationEndDate  DateTime?
  salaryAmount      Decimal?       @db.Decimal(14, 2)
  salaryCurrency    String         @default("PKR")
  attendanceNotes   String?
  performanceNotes  String?
  warnings          String?
  contractStatus    String?
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents         Document[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model Candidate {
  id                  String         @id @default(cuid())
  name                String
  roleAppliedFor      String
  phone               String?
  email               String?
  cvUrl               String?
  expectedSalary      Decimal?       @db.Decimal(14, 2)
  interviewNotes      String?
  rating              Int?
  stage               CandidateStage @default(APPLIED)
  assignedInterviewerId String?
  assignedInterviewer User?          @relation("CandidateInterviewer", fields: [assignedInterviewerId], references: [id])
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
}

model ProcurementItem {
  id            String              @id @default(cuid())
  itemName      String
  category      ProcurementCategory
  vendor        String?
  estimatedCost Decimal?            @db.Decimal(14, 2)
  actualCost    Decimal?            @db.Decimal(14, 2)
  status        ProcurementStatus   @default(NEEDED)
  assignedPersonId String?
  dueDate       DateTime?
  paymentStatus PaymentStatus       @default(PENDING)
  receiptUrl    String?
  notes         String?
  assignedPerson User?              @relation("ProcurementAssigned", fields: [assignedPersonId], references: [id])
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model Expense {
  id            String        @id @default(cuid())
  title         String
  amount        Decimal       @db.Decimal(14, 2)
  category      String
  projectId     String?
  departmentId  String?
  paidById      String?
  approvedById  String?
  date          DateTime      @default(now())
  paymentMethod String?
  receiptUrl    String?
  status        ExpenseStatus @default(PENDING)
  project       Project?      @relation(fields: [projectId], references: [id])
  paidBy        User?         @relation("ExpensePaidBy", fields: [paidById], references: [id])
  approvedBy    User?         @relation("ExpenseApprovedBy", fields: [approvedById], references: [id])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Meeting {
  id              String             @id @default(cuid())
  title           String
  scheduledAt     DateTime
  organizerId     String?
  projectId       String?
  agenda          String?
  notes           String?
  decisions       String?
  followUpDate    DateTime?
  attachmentUrl   String?
  organizer       User?              @relation("MeetingOrganizer", fields: [organizerId], references: [id])
  project         Project?           @relation(fields: [projectId], references: [id])
  participants    MeetingParticipant[]
  actionItems     MeetingActionItem[]
  comments        Comment[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model MeetingParticipant {
  id        String   @id @default(cuid())
  meetingId String
  userId    String
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
}

model MeetingActionItem {
  id          String   @id @default(cuid())
  meetingId   String
  taskId      String?
  title       String
  ownerId     String?
  dueDate     DateTime?
  completed   Boolean  @default(false)
  meeting     Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  task        Task?    @relation(fields: [taskId], references: [id])
  createdAt   DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String?
  type      String
  readAt    DateTime?
  href      String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId, readAt])
}

model AuditLog {
  id         String         @id @default(cuid())
  actorId    String?
  action     ActivityAction
  entityType String
  entityId   String?
  summary    String
  metadata   Json?
  ipAddress  String?
  actor      User?          @relation("AuditActor", fields: [actorId], references: [id])
  createdAt  DateTime       @default(now())

  @@index([actorId])
  @@index([entityType, entityId])
}
